    // Direct fetch helper for Gemini conversational queries
    async function callGeminiChatAPI(chatHistory, systemInstruction) {
      const apiKey = ""; // Canvas runtime injects actual API key
      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

      const payload = {
        contents: chatHistory,
        systemInstruction: {
          parts: [{ text: systemInstruction }]
        }
      };

      let delay = 1000;
      for (let attempt = 0; attempt < 5; attempt++) {
        try {
          const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          
          const result = await response.json();
          const replyText = result.candidates?.[0]?.content?.parts?.[0]?.text;
          if (replyText) return replyText;
          throw new Error("Empty response");
        } catch (error) {
          if (attempt === 4) throw error;
          await new Promise(r => setTimeout(r, delay));
          delay *= 2;
        }
      }
    }

    // Markdown Parser helper to elegantly convert AI response text to standard HTML
    function formatMarkdownToHTML(markdown) {
      if (!markdown) return '';
      let html = markdown
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

      // Convert bold (**text**)
      html = html.replace(/\*\*(.*?)\*\*/g, '<strong class="font-extrabold text-indigo-900 dark:text-indigo-300">$1</strong>');
      // Convert italic (*text*)
      html = html.replace(/\*(.*?)\*/g, '<em class="italic">$1</em>');
      // Convert list items
      html = html.replace(/^\s*-\s+(.*?)$/gm, '<li class="list-disc list-inside ml-2 my-1 text-slate-700 dark:text-neutral-300">$1</li>');
      // Convert headers
      html = html.replace(/^### (.*?)$/gm, '<h5 class="text-xs font-bold text-slate-800 dark:text-white mt-3 mb-1.5">$1</h5>');
      html = html.replace(/^## (.*?)$/gm, '<h4 class="text-sm font-bold text-slate-900 dark:text-white mt-3 mb-1.5">$1</h4>');
      // Convert Linebreaks
      html = html.replace(/\n/g, '<br>');

      return html;
    }


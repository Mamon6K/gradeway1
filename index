<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GradWay - ระบบตรวจสอบและวางแผนการเรียนสำหรับนักศึกษา</title>
  
  <!-- Fonts: Inter & LINE Seed Sans TH -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: 'var(--primary-color)',
            'primary-hover': 'var(--primary-hover)',
            'primary-light': 'var(--primary-light)',
          },
          fontFamily: {
            sans: ['Inter', 'Noto Sans Thai', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --primary-color: #4f46e5;
      --primary-hover: #4338ca;
      --primary-light: #eeebff;
    }

    /* Theme Styles */
    .theme-slate {
      --primary-color: #475569;
      --primary-hover: #334155;
      --primary-light: #f1f5f9;
    }
    .theme-blue {
      --primary-color: #2563eb;
      --primary-hover: #1d4ed8;
      --primary-light: #eff6ff;
    }
    .theme-green {
      --primary-color: #059669;
      --primary-hover: #047857;
      --primary-light: #ecfdf5;
    }
    .theme-orange {
      --primary-color: #ea580c;
      --primary-hover: #ca8a04;
      --primary-light: #fff7ed;
    }
    .theme-purple {
      --primary-color: #7c3aed;
      --primary-hover: #6d28d9;
      --primary-light: #f5f3ff;
    }

    .dark {
      --primary-light: rgba(255, 255, 255, 0.05);
    }

    body {
      font-family: 'Inter', 'Noto Sans Thai', sans-serif;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 dark:bg-neutral-950 dark:text-neutral-200 min-h-screen theme-slate">

  <!-- Navbar -->
  <nav class="sticky top-0 z-40 backdrop-blur-md bg-white/80 dark:bg-neutral-950/80 border-b border-slate-200 dark:border-neutral-800 transition-colors">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <!-- Logo -->
        <div class="flex items-center gap-2.5">
          <div class="p-2 rounded-xl bg-primary text-white transition-colors duration-300">
            <i data-lucide="graduation-cap" class="w-6 h-6"></i>
          </div>
          <span class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">GradWay</span>
        </div>

        <!-- Right Menu Controls -->
        <div class="flex items-center gap-2 sm:gap-4">
          <!-- Navigation Tabs -->
          <div class="flex bg-slate-100 dark:bg-neutral-900 p-1 rounded-xl">
            <button onclick="switchTab('dashboard')" id="tab-dashboard" class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-all text-primary bg-white dark:bg-neutral-800 shadow-sm">
              <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
              <span class="hidden md:inline">Dashboard</span>
            </button>
            <button onclick="switchTab('plan')" id="tab-plan" class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-all text-slate-500 dark:text-neutral-400">
              <i data-lucide="book-open" class="w-4 h-4"></i>
              <span class="hidden md:inline">แผนการเรียน</span>
            </button>
          </div>

          <!-- Vertical Divider -->
          <div class="h-6 w-px bg-slate-200 dark:bg-neutral-800"></div>

          <!-- Theme & Dark Mode Controls -->
          <div class="flex items-center gap-2">
            <!-- Theme Circle Selector Dropdown -->
            <div class="relative group">
              <button class="p-2 hover:bg-slate-100 dark:hover:bg-neutral-900 rounded-xl transition-colors" title="เปลี่ยนโทนสีธีม">
                <i data-lucide="palette" class="w-5 h-5 text-slate-500 dark:text-neutral-400"></i>
              </button>
              <div class="absolute right-0 mt-2 w-40 bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-xl shadow-lg p-2 hidden group-hover:block hover:block transition-all">
                <div class="grid grid-cols-5 gap-2 justify-items-center">
                  <button onclick="setTheme('slate')" class="w-6 h-6 rounded-full bg-slate-600 border border-white" title="Slate"></button>
                  <button onclick="setTheme('blue')" class="w-6 h-6 rounded-full bg-blue-600 border border-white" title="Blue"></button>
                  <button onclick="setTheme('green')" class="w-6 h-6 rounded-full bg-emerald-600 border border-white" title="Green"></button>
                  <button onclick="setTheme('orange')" class="w-6 h-6 rounded-full bg-orange-600 border border-white" title="Orange"></button>
                  <button onclick="setTheme('purple')" class="w-6 h-6 rounded-full bg-purple-600 border border-white" title="Purple"></button>
                </div>
              </div>
            </div>

            <!-- Dark Mode Toggle -->
            <button onclick="toggleDarkMode()" class="p-2 hover:bg-slate-100 dark:hover:bg-neutral-900 rounded-xl transition-colors" title="สลับโหมด มืด/สว่าง">
              <i data-lucide="sun" id="sun-icon" class="w-5 h-5 text-amber-500 hidden"></i>
              <i data-lucide="moon" id="moon-icon" class="w-5 h-5 text-slate-500 dark:text-neutral-400"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Container -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Student Profile Edit Area (Always visible on top, elegantly styled) -->
    <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 mb-8 transition-all shadow-sm">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-primary-light text-primary flex items-center justify-center font-bold text-lg">
            <span id="profile-avatar-letters">ST</span>
          </div>
          <div>
            <div class="flex items-center gap-2 group">
              <h2 id="display-student-name" class="text-xl font-bold text-slate-900 dark:text-white">สมชาย รักเรียน</h2>
              <button onclick="openProfileModal()" class="p-1 hover:bg-slate-100 dark:hover:bg-neutral-800 text-slate-400 hover:text-slate-600 dark:hover:text-neutral-300 rounded-lg transition-colors">
                <i data-lucide="edit-3" class="w-4 h-4"></i>
              </button>
            </div>
            <p id="display-student-id" class="text-sm text-slate-500 dark:text-neutral-400">รหัสนักศึกษา: 66010999</p>
          </div>
        </div>

        <!-- Extra Parameters for Honors check -->
        <div class="flex flex-wrap gap-4 items-center bg-slate-50 dark:bg-neutral-800/40 p-4 rounded-xl border border-slate-100 dark:border-neutral-800">
          <div class="flex items-center gap-2">
            <input type="checkbox" id="param-retaken" onchange="toggleParam('retaken')" class="w-4 h-4 text-primary bg-gray-100 border-gray-300 rounded focus:ring-primary dark:bg-neutral-700 dark:border-neutral-600">
            <label for="param-retaken" class="text-xs font-medium text-slate-600 dark:text-neutral-300 cursor-pointer">เคยลงทะเบียนเรียนซ้ำ (เพื่อปรับเกรด)</label>
          </div>
          <div class="h-4 w-px bg-slate-200 dark:bg-neutral-700 hidden md:block"></div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="param-overtime" onchange="toggleParam('overtime')" class="w-4 h-4 text-primary bg-gray-100 border-gray-300 rounded focus:ring-primary dark:bg-neutral-700 dark:border-neutral-600">
            <label for="param-overtime" class="text-xs font-medium text-slate-600 dark:text-neutral-300 cursor-pointer">เรียนจบเกินเวลาหลักสูตร (เกิน 4 ปี)</label>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: DASHBOARD -->
    <div id="view-dashboard" class="space-y-8">
      
      <!-- Top Overview Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Stat: GPAX -->
        <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm relative overflow-hidden">
          <div class="absolute -right-6 -top-6 w-20 h-20 bg-primary opacity-5 rounded-full blur-xl"></div>
          <p class="text-xs font-medium text-slate-400 dark:text-neutral-500 uppercase tracking-wider mb-1">GPAX สะสม</p>
          <p id="stat-gpax" class="text-3xl font-extrabold text-primary">0.00</p>
          <p id="stat-gpax-desc" class="text-xs text-slate-500 dark:text-neutral-400 mt-2">คำนวณจากทุกวิชาที่ลงทะเบียน</p>
        </div>

        <!-- Stat: Credits Registered -->
        <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm relative overflow-hidden">
          <p class="text-xs font-medium text-slate-400 dark:text-neutral-500 uppercase tracking-wider mb-1">หน่วยกิตสะสม</p>
          <div class="flex items-baseline gap-1">
            <span id="stat-credits" class="text-3xl font-extrabold text-slate-900 dark:text-white">0</span>
            <span class="text-sm text-slate-400">/ 133</span>
          </div>
          <p id="stat-credits-desc" class="text-xs text-slate-500 dark:text-neutral-400 mt-2">ผ่านเกณฑ์แล้ว 0% ของเป้าหมาย</p>
        </div>

        <!-- Stat: Student Status -->
        <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm relative overflow-hidden">
          <p class="text-xs font-medium text-slate-400 dark:text-neutral-500 uppercase tracking-wider mb-1">สถานภาพนักศึกษา</p>
          <p id="stat-status" class="text-3xl font-extrabold text-emerald-500">ปกติ</p>
          <p id="stat-status-desc" class="text-xs text-slate-500 dark:text-neutral-400 mt-2">เกรดเฉลี่ยสะสมปลอดภัย (>= 2.00)</p>
        </div>

        <!-- Stat: Honors Forecast -->
        <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm relative overflow-hidden">
          <p class="text-xs font-medium text-slate-400 dark:text-neutral-500 uppercase tracking-wider mb-1">คาดการณ์เกียรตินิยม</p>
          <p id="stat-honors" class="text-2xl font-extrabold text-slate-900 dark:text-white truncate">ไม่มีสิทธิ์</p>
          <p id="stat-honors-desc" class="text-xs text-slate-500 dark:text-neutral-400 mt-3">รักษาระดับเกรดและเงื่อนไข</p>
        </div>
      </div>

      <!-- Main Dashboard Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Auto Checklist Structure -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-lg font-bold text-slate-900 dark:text-white">ระบบเช็คลิสต์หมวดหมู่วิชาอัตโนมัติ</h3>
              <span class="text-xs bg-slate-100 dark:bg-neutral-800 text-slate-600 dark:text-neutral-300 px-2.5 py-1 rounded-full font-medium">เกณฑ์หลักสูตร 133 นก.</span>
            </div>

            <!-- Categories Checklist -->
            <div class="space-y-6">
              
              <!-- 1. General Education -->
              <div class="space-y-2 border-b border-slate-100 dark:border-neutral-800/60 pb-5">
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-2">
                    <button onclick="toggleSection('sub-gened')" class="p-1 hover:bg-slate-100 dark:hover:bg-neutral-800 rounded-lg">
                      <i data-lucide="chevron-down" id="chevron-sub-gened" class="w-4 h-4 text-slate-400 transition-transform"></i>
                    </button>
                    <span class="font-semibold text-sm sm:text-base">หมวดศึกษาทั่วไป (General Education)</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span id="badge-gened" class="text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400">0 / 33 นก.</span>
                    <i data-lucide="circle-dashed" id="icon-gened" class="w-5 h-5 text-slate-300"></i>
                  </div>
                </div>
                <!-- Mini Progress Bar -->
                <div class="h-2 w-full bg-slate-100 dark:bg-neutral-800 rounded-full overflow-hidden">
                  <div id="progress-gened" class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>

                <!-- Sub-GenEd Items -->
                <div id="sub-gened" class="hidden pl-6 pt-2 space-y-3">
                  <!-- Thai -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.1 กลุ่มวิชาภาษาไทย (ไม่น้อยกว่า 3 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-thai">0 / 3</span>
                      <i id="chk-sub-thai" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Foreign Lang -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.2 กลุ่มวิชาภาษาต่างประเทศ (ไม่น้อยกว่า 6 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-eng">0 / 6</span>
                      <i id="chk-sub-eng" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Sci -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.3 กลุ่มวิชาวิทยาศาสตร์ (ไม่น้อยกว่า 3 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-sci">0 / 3</span>
                      <i id="chk-sub-sci" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Math -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.4 กลุ่มวิชาคณิตศาสตร์ (ไม่น้อยกว่า 3 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-math">0 / 3</span>
                      <i id="chk-sub-math" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Soc -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.5 กลุ่มวิชาสังคมศาสตร์ (ไม่น้อยกว่า 3 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-soc">0 / 3</span>
                      <i id="chk-sub-soc" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Hum -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.6 กลุ่มวิชามนุษยศาสตร์ (ไม่น้อยกว่า 3 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-hum">0 / 3</span>
                      <i id="chk-sub-hum" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- General Elec -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">1.7 ศึกษาทั่วไปเลือกเพิ่มเติม เพื่อให้ครบ 33 หน่วยกิต</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-genelec">0 / 12</span>
                      <i id="chk-sub-genelec" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 2. Core Curriculum -->
              <div class="space-y-2 border-b border-slate-100 dark:border-neutral-800/60 pb-5">
                <div class="flex justify-between items-center">
                  <span class="font-semibold text-sm sm:text-base">กลุ่มวิชาแกน (Core Courses)</span>
                  <div class="flex items-center gap-2">
                    <span id="badge-core" class="text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400">0 / 27 นก.</span>
                    <i data-lucide="circle-dashed" id="icon-core" class="w-5 h-5 text-slate-300"></i>
                  </div>
                </div>
                <div class="h-2 w-full bg-slate-100 dark:bg-neutral-800 rounded-full overflow-hidden">
                  <div id="progress-core" class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
              </div>

              <!-- 3. Specialty/Major Courses -->
              <div class="space-y-2 border-b border-slate-100 dark:border-neutral-800/60 pb-5">
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-2">
                    <button onclick="toggleSection('sub-spec')" class="p-1 hover:bg-slate-100 dark:hover:bg-neutral-800 rounded-lg">
                      <i data-lucide="chevron-down" id="chevron-sub-spec" class="w-4 h-4 text-slate-400 transition-transform"></i>
                    </button>
                    <span class="font-semibold text-sm sm:text-base">กลุ่มวิชาเฉพาะ (Specialty Courses)</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span id="badge-spec" class="text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400">0 / 67 นก.</span>
                    <i data-lucide="circle-dashed" id="icon-spec" class="w-5 h-5 text-slate-300"></i>
                  </div>
                </div>
                <div class="h-2 w-full bg-slate-100 dark:bg-neutral-800 rounded-full overflow-hidden">
                  <div id="progress-spec" class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>

                <!-- Sub Specialty Items -->
                <div id="sub-spec" class="hidden pl-6 pt-2 space-y-3">
                  <!-- Compulsory -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">กลุ่มวิชาชีพบังคับ (ไม่น้อยกว่า 52 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-compulsory">0 / 52</span>
                      <i id="chk-sub-compulsory" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                  <!-- Elective -->
                  <div class="flex justify-between items-center text-xs">
                    <span class="text-slate-500 dark:text-neutral-400">กลุ่มวิชาชีพเลือก (ไม่น้อยกว่า 15 นก.)</span>
                    <div class="flex items-center gap-1.5 font-medium">
                      <span id="txt-sub-specelec">0 / 15</span>
                      <i id="chk-sub-specelec" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300"></i>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 4. Free Elective -->
              <div class="space-y-2 pb-2">
                <div class="flex justify-between items-center">
                  <span class="font-semibold text-sm sm:text-base">หมวดเลือกเสรี (Free Elective)</span>
                  <div class="flex items-center gap-2">
                    <span id="badge-free" class="text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400">0 / 6 นก.</span>
                    <i data-lucide="circle-dashed" id="icon-free" class="w-5 h-5 text-slate-300"></i>
                  </div>
                </div>
                <div class="h-2 w-full bg-slate-100 dark:bg-neutral-800 rounded-full overflow-hidden">
                  <div id="progress-free" class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Right: Trend Chart, AI Assistant & System Explanations -->
        <div class="space-y-6">
          
          <!-- ✨ AI Advisor Section (Interactive Chatbot) -->
          <div id="ai-mentor-card" class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl p-5 shadow-md relative overflow-hidden flex flex-col h-[520px]">
            <!-- Card Background Glow -->
            <div class="absolute -right-12 -top-12 w-32 h-32 bg-indigo-500 opacity-5 rounded-full blur-3xl pointer-events-none"></div>
            
            <!-- Header -->
            <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-neutral-800/80 shrink-0">
              <div class="flex items-center gap-2.5">
                <div class="p-1.5 bg-indigo-100 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 rounded-lg">
                  <i data-lucide="sparkles" class="w-5 h-5 animate-pulse"></i>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-900 dark:text-white">GradWay AI Mentor</h3>
                  <span class="text-[9px] text-emerald-500 font-medium flex items-center gap-1">
                    <span class="w-1 h-1 rounded-full bg-emerald-500 animate-ping"></span> พร้อมคุยถามตอบ
                  </span>

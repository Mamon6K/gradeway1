    // --- Semester Operations ---
    function addNewSemester() {
      let nextYear = 1;
      let nextTerm = 1;

      if (appState.semesters.length > 0) {
        // Sort semesters to find the latest
        const sorted = [...appState.semesters].sort((a,b) => {
          if (a.year !== b.year) return a.year - b.year;
          return a.term - b.term;
        });
        const latest = sorted[sorted.length - 1];
        if (latest.term === 1) {
          nextYear = latest.year;
          nextTerm = 2;
        } else if (latest.term === 2) {
          nextYear = latest.year;
          nextTerm = 3; // Summer
        } else {
          nextYear = latest.year + 1;
          nextTerm = 1;
        }
      }

      const newSem = {
        id: 'sem-' + Date.now(),
        year: nextYear,
        term: nextTerm,
        courses: []
      };

      appState.semesters.push(newSem);
      saveToLocalStorage();
      renderApp();
    }


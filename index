        if (hasF) reason = "มีเกรด F ในประวัติ";
        else if (appState.params.retaken) reason = "มีประวัติลงเรียนซ้ำ";
        else if (appState.params.overtime) reason = "จบเกินกำหนด 4 ปี";
        else if (totalPassedCredits === 0) reason = "ยังไม่มีข้อมูลเกรด";
        honorsDescEl.textContent = reason;
      } else if (currentGPAX >= 3.75) {
        honorsEl.textContent = "เกียรตินิยมอันดับ 1";
        honorsEl.className = "text-2xl font-extrabold text-emerald-500 truncate";
        honorsDescEl.textContent = "ยอดเยี่ยม! รักษาระดับไว้นะครับ";
      } else if (currentGPAX >= 3.25) {
        honorsEl.textContent = "เกียรตินิยมอันดับ 2";
        honorsEl.className = "text-2xl font-extrabold text-blue-500 truncate";
        honorsDescEl.textContent = "เกรดสะสมอยู่ในเกณฑ์เกียรตินิยมอันดับ 2";
      } else {
        honorsEl.textContent = "ผ่านเกณฑ์ปกติ";
        honorsEl.className = "text-2xl font-extrabold text-slate-800 dark:text-neutral-200 truncate";
        honorsDescEl.textContent = "เกรดเฉลี่ยต่ำกว่าเกณฑ์เกียรตินิยม (< 3.25)";
      }

      // 4. Render Auto Checklist & Progress bar calculations
      const genEdTotalEarned = creditsMap.GEN_THAI + creditsMap.GEN_ENG + creditsMap.GEN_SCI + 
                               creditsMap.GEN_MATH + creditsMap.GEN_SOC + creditsMap.GEN_HUM + creditsMap.GEN_ELEC;
      const coreEarned = creditsMap.CORE;
      const specTotalEarned = creditsMap.SPEC_COMPULSORY + creditsMap.SPEC_ELECTIVE;
      const freeEarned = creditsMap.FREE_ELECTIVE;

      // Update Gened Elements
      updateProgressUI('gened', genEdTotalEarned, 33);
      updateSubItemUI('thai', creditsMap.GEN_THAI, 3);
      updateSubItemUI('eng', creditsMap.GEN_ENG, 6);
      updateSubItemUI('sci', creditsMap.GEN_SCI, 3);
      updateSubItemUI('math', creditsMap.GEN_MATH, 3);
      updateSubItemUI('soc', creditsMap.GEN_SOC, 3);
      updateSubItemUI('hum', creditsMap.GEN_HUM, 3);
      updateSubItemUI('genelec', creditsMap.GEN_ELEC, 12);

      // Update Core Elements
      updateProgressUI('core', coreEarned, 27);

      // Update Spec Elements
      updateProgressUI('spec', specTotalEarned, 67);
      updateSubItemUI('compulsory', creditsMap.SPEC_COMPULSORY, 52);
      updateSubItemUI('specelec', creditsMap.SPEC_ELECTIVE, 15);

      // Update Free Elective
      updateProgressUI('free', freeEarned, 6);

      // 5. Drawing the Minimal SVG GPA Trend Graph
      drawGpaTrendChart(semesterGPAData);

      // 6. Plan / Semesters renderer
      const semestersListContainer = document.getElementById('semesters-list');
      const emptyStateEl = document.getElementById('empty-state');

      if (appState.semesters.length === 0) {
        emptyStateEl.classList.remove('hidden');
        semestersListContainer.innerHTML = "";
      } else {
        emptyStateEl.classList.add('hidden');
        semestersListContainer.innerHTML = sortedSemesters.map(sem => {
          // Calculate semester statistics
          let semCredits = 0;
          let semGradePoints = 0;
          sem.courses.forEach(c => {
            if (c.grade !== 'S' && c.grade !== 'U' && c.grade !== '-') {
              const pts = GRADE_POINTS[c.grade];
              if (pts !== undefined) {
                semCredits += c.credits;
                semGradePoints += (pts * c.credits);
              }
            }
          });
          const semGPA = semCredits > 0 ? (semGradePoints / semCredits).toFixed(2) : '0.00';

          return `
            <div class="bg-white dark:bg-neutral-900 border border-slate-200 dark:border-neutral-800 rounded-2xl overflow-hidden shadow-sm transition-colors duration-300">
              <!-- Semester Header Card -->
              <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 dark:border-neutral-800/80 bg-slate-50/50 dark:bg-neutral-900/50">
                <div class="flex items-center gap-3">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold text-slate-400 dark:text-neutral-500 uppercase tracking-wider">ปีการศึกษา</span>
                    <select onchange="updateSemesterMeta('${sem.id}', 'year', this.value)" class="text-base font-bold bg-transparent border-none focus:ring-0 p-0 text-slate-800 dark:text-white cursor-pointer outline-none">
                      ${[1,2,3,4,5,6,7,8].map(y => `<option value="${y}" ${sem.year === y ? 'selected' : ''} class="text-slate-900">${y}</option>`).join('')}
                    </select>
                  </div>
                  <span class="text-slate-300 dark:text-neutral-700">/</span>
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold text-slate-400 dark:text-neutral-500 uppercase tracking-wider">ภาคเรียน</span>
                    <select onchange="updateSemesterMeta('${sem.id}', 'term', this.value)" class="text-base font-bold bg-transparent border-none focus:ring-0 p-0 text-slate-800 dark:text-white cursor-pointer outline-none">
                      <option value="1" ${sem.term === 1 ? 'selected' : ''} class="text-slate-900">1</option>
                      <option value="2" ${sem.term === 2 ? 'selected' : ''} class="text-slate-900">2</option>
                      <option value="3" ${sem.term === 3 ? 'selected' : ''} class="text-slate-900">3 (Summer)</option>
                    </select>
                  </div>
                </div>

                <div class="flex items-center gap-6">
                  <div class="text-left sm:text-right">
                    <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">GPA ภาคเรียน</p>
                    <p class="text-lg font-extrabold text-primary">${semGPA}</p>
                  </div>
                  <button onclick="deleteSemester('${sem.id}')" class="p-2 hover:bg-red-50 dark:hover:bg-red-950/20 text-slate-400 hover:text-red-500 rounded-xl transition-colors" title="ลบเทอมนี้">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>

              <!-- Courses List within Semester Card -->
              <div class="p-6">
                
                ${sem.courses.length === 0 ? `
                  <div class="text-center py-8 text-xs text-slate-400 dark:text-neutral-500">
                    ยังไม่มีรายวิชาที่ลงทะเบียนในภาคเรียนนี้
                  </div>
                ` : `
                  <!-- Table Header -->
                  <div class="hidden md:grid grid-cols-12 gap-4 pb-2 mb-3 border-b border-slate-100 dark:border-neutral-800/40 text-xs font-semibold text-slate-400 dark:text-neutral-500">
                    <div class="col-span-2">รหัสวิชา</div>
                    <div class="col-span-4">ชื่อวิชา</div>
                    <div class="col-span-3">กลุ่มวิชา</div>
                    <div class="col-span-1 text-center">หน่วยกิต</div>
                    <div class="col-span-1 text-center">เกรด</div>
                    <div class="col-span-1"></div>
                  </div>

                  <!-- Table List Items -->
                  <div class="space-y-3">
                    ${sem.courses.map(course => `
                      <div class="flex flex-col md:grid md:grid-cols-12 gap-3 md:gap-4 p-4 md:p-2 bg-slate-50 dark:bg-neutral-800/30 md:bg-transparent rounded-xl md:rounded-none border border-slate-100 dark:border-neutral-800/50 md:border-none items-center group">
                        
                        <!-- Course Code -->
                        <div class="col-span-2 w-full md:w-auto font-semibold text-sm text-slate-900 dark:text-white uppercase">
                          <span class="text-slate-400 md:hidden text-xs font-normal block mb-0.5">รหัสวิชา</span>
                          ${course.code}
                        </div>

                        <!-- Course Name -->
                        <div class="col-span-4 w-full md:w-auto text-sm text-slate-700 dark:text-neutral-300">
                          <span class="text-slate-400 md:hidden text-xs font-normal block mb-0.5">ชื่อวิชา</span>
                          ${course.name}
                        </div>

                        <!-- Course Category Badge -->
                        <div class="col-span-3 w-full md:w-auto text-xs">
                          <span class="text-slate-400 md:hidden text-xs font-normal block mb-1">กลุ่มวิชา</span>
                          <span class="inline-block px-2 py-1 rounded-md bg-slate-100 dark:bg-neutral-800 text-slate-600 dark:text-neutral-300 max-w-full truncate">
                            ${CATEGORIES[course.category]}
                          </span>
                        </div>

                        <!-- Course Credits -->
                        <div class="col-span-1 w-full md:w-auto text-center text-sm font-medium">
                          <span class="text-slate-400 md:hidden text-xs font-normal block mb-0.5">หน่วยกิต</span>
                          ${course.credits}
                        </div>

                        <!-- Course Grade -->
                        <div class="col-span-1 w-full md:w-auto text-center">
                          <span class="text-slate-400 md:hidden text-xs font-normal block mb-0.5">ผลการเรียน</span>
                          <span class="inline-block px-2.5 py-0.5 rounded-lg text-xs font-bold ${
                            course.grade === 'F' || course.grade === 'U' 
                              ? 'bg-red-50 text-red-500 dark:bg-red-950/25' 
                              : course.grade === 'A' 
                              ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/25'
                              : 'bg-primary-light text-primary'
                          }">
                            ${course.grade}
                          </span>
                        </div>

                        <!-- Actions Area -->
                        <div class="col-span-1 w-full md:w-auto flex items-center justify-end gap-2 pt-2 md:pt-0 border-t md:border-none border-slate-100 dark:border-neutral-800">
                          <button onclick="openCourseModal('${sem.id}', '${course.id}')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-neutral-800 text-slate-400 hover:text-slate-600 dark:hover:text-neutral-300 rounded-lg transition-colors" title="แก้ไขวิชา">
                            <i data-lucide="edit-2" class="w-3.5 h-3.5"></i>
                          </button>
                          <button onclick="deleteCourse('${sem.id}', '${course.id}')" class="p-1.5 hover:bg-red-50 dark:hover:bg-red-950/20 text-slate-400 hover:text-red-500 rounded-lg transition-colors" title="ลบวิชา">
                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                          </button>
                        </div>

                      </div>
                    `).join('')}
                  </div>
                `}

                <!-- Add Course Button Inside Semester -->
                <button onclick="openCourseModal('${sem.id}')" class="mt-4 w-full py-2.5 rounded-xl border border-dashed border-slate-200 dark:border-neutral-800 hover:border-primary text-slate-400 hover:text-primary transition-all text-xs font-semibold flex items-center justify-center gap-1.5">
                  <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                  เพิ่มรายวิชา
                </button>

              </div>
            </div>
          `;
        }).join('');
      }

      // Re-trigger Lucide Icons rendering
      lucide.createIcons();
    }

    // --- Auto Checklist Helper Utilities ---
    function updateProgressUI(id, earned, required) {
      const bar = document.getElementById(`progress-${id}`);
      const badge = document.getElementById(`badge-${id}`);
      const icon = document.getElementById(`icon-${id}`);

      const percent = Math.min(100, Math.round((earned / required) * 100)) || 0;
      if (bar) bar.style.width = `${percent}%`;
      
      if (badge) {
        badge.textContent = `${earned} / ${required} นก.`;
        if (earned >= required) {
          badge.className = "text-xs font-semibold px-2 py-0.5 rounded bg-emerald-50 text-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-400 animate-pulse";
        } else {
          badge.className = "text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400";
        }
      }

      if (icon) {
        if (earned >= required) {
          icon.outerHTML = `<i data-lucide="check-circle-2" id="icon-${id}" class="w-5 h-5 text-emerald-500 shrink-0"></i>`;
        } else {
          icon.outerHTML = `<i data-lucide="circle-dashed" id="icon-${id}" class="w-5 h-5 text-slate-300 dark:text-neutral-700 shrink-0"></i>`;
        }
      }
    }

    function updateSubItemUI(id, earned, required) {
      const txt = document.getElementById(`txt-sub-${id}`);
      const icon = document.getElementById(`chk-sub-${id}`);

      if (txt) txt.textContent = `${earned} / ${required}`;
      if (icon) {
        if (earned >= required) {
          icon.outerHTML = `<i id="chk-sub-${id}" data-lucide="check-circle-2" class="w-3.5 h-3.5 text-emerald-500 shrink-0"></i>`;
        } else {
          icon.outerHTML = `<i id="chk-sub-${id}" data-lucide="circle" class="w-3.5 h-3.5 text-slate-300 dark:text-neutral-700 shrink-0"></i>`;
        }
      }
    }

    // --- Custom SVG Bar/Line graph plotter ---
    function drawGpaTrendChart(data) {
      const container = document.getElementById('chart-container');
      const svg = document.getElementById('trend-svg');
      const labelContainer = document.getElementById('chart-labels');
      
      // Clear current elements
      svg.innerHTML = '';
      labelContainer.innerHTML = '';

      if (data.length === 0) {
        container.classList.add('hidden');
        return;
      } else {
        container.classList.remove('hidden');
      }

      // Filter out terms with no grade points
      const validPoints = data.map((d, index) => ({
        x: data.length > 1 ? (index / (data.length - 1)) * 100 : 50,
        y: 100 - (d.gpa / 4.0) * 100, // Inverse since SVG is 0 at top
        label: d.label,
        gpa: d.gpa
      }));

      // Create line path
      if (validPoints.length > 1) {
        let pathD = `M ${validPoints[0].x} ${validPoints[0].y}`;
        for (let i = 1; i < validPoints.length; i++) {
          pathD += ` L ${validPoints[i].x} ${validPoints[i].y}`;
        }
        
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', pathD);
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke', 'var(--primary-color)');
        path.setAttribute('stroke-width', '3');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        svg.appendChild(path);
      }

      // Create dots and tooltips
      validPoints.forEach(p => {
        const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        group.setAttribute('class', 'group/dot');
        
        // Outer glow on hover
        const outerCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        outerCircle.setAttribute('cx', p.x);
        outerCircle.setAttribute('cy', p.y);
        outerCircle.setAttribute('r', '8');
        outerCircle.setAttribute('fill', 'var(--primary-color)');
        outerCircle.setAttribute('opacity', '0');
        outerCircle.setAttribute('class', 'transition-all duration-300 hover:opacity-25 cursor-pointer');
        
        // Main dot
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', p.x);
        circle.setAttribute('cy', p.y);
        circle.setAttribute('r', '4');
        circle.setAttribute('fill', 'var(--primary-color)');
        circle.setAttribute('stroke', '#ffffff');
        circle.setAttribute('stroke-width', '1.5');
        circle.setAttribute('class', 'cursor-pointer');

        // Dynamic text value indicator
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', p.x);
        text.setAttribute('y', p.y - 10);
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('fill', 'var(--primary-color)');
        text.setAttribute('font-size', '8px');
        text.setAttribute('font-weight', 'bold');
        text.textContent = p.gpa.toFixed(2);

        group.appendChild(outerCircle);
        group.appendChild(circle);
        group.appendChild(text);
        svg.appendChild(group);

        // Add corresponding label to bottom
        const lbl = document.createElement('span');
        lbl.className = "truncate text-[9px] font-semibold text-center";
        lbl.style.width = `${100 / data.length}%`;
        lbl.textContent = p.label;
        labelContainer.appendChild(lbl);
      });
    }

  </script>

</body>
</html>
